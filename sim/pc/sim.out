#! /opt/homebrew/Cellar/icarus-verilog/12.0/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/system.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/vhdl_sys.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/vhdl_textio.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/v2005_math.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/va_math.vpi";
:vpi_module "/opt/homebrew/Cellar/icarus-verilog/12.0/lib/ivl/v2009.vpi";
S_0x1567076d0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x156705950 .scope module, "pc_tb" "pc_tb" 3 2;
 .timescale -9 -12;
v0x15671da00_0 .var "clk", 0 0;
v0x15671daa0_0 .var "pc_next_i", 31 0;
v0x15671db50_0 .net "pc_o", 31 0, v0x15671d840_0;  1 drivers
v0x15671dc20_0 .var "rst_n", 0 0;
S_0x156705ac0 .scope module, "UUT" "pc" 3 8, 4 2 0, S_0x156705950;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "rst_n";
    .port_info 2 /INPUT 32 "pc_next_i";
    .port_info 3 /OUTPUT 32 "pc_o";
v0x156707840_0 .net "clk", 0 0, v0x15671da00_0;  1 drivers
v0x15671d790_0 .net "pc_next_i", 31 0, v0x15671daa0_0;  1 drivers
v0x15671d840_0 .var "pc_o", 31 0;
v0x15671d900_0 .net "rst_n", 0 0, v0x15671dc20_0;  1 drivers
E_0x156705c30/0 .event negedge, v0x15671d900_0;
E_0x156705c30/1 .event posedge, v0x156707840_0;
E_0x156705c30 .event/or E_0x156705c30/0, E_0x156705c30/1;
    .scope S_0x156705ac0;
T_0 ;
    %wait E_0x156705c30;
    %load/vec4 v0x15671d900_0;
    %nor/r;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 32;
    %assign/vec4 v0x15671d840_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x15671d790_0;
    %assign/vec4 v0x15671d840_0, 0;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x156705950;
T_1 ;
    %delay 5000, 0;
    %load/vec4 v0x15671da00_0;
    %inv;
    %store/vec4 v0x15671da00_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x156705950;
T_2 ;
    %vpi_call/w 3 18 "$dumpfile", "sim.vcd" {0 0 0};
    %vpi_call/w 3 19 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x156705950 {0 0 0};
    %vpi_call/w 3 20 "$monitor", "TIME=%0t | rst_n=%b | pc_next_i=%0d | pc_o=%0d", $time, v0x15671dc20_0, v0x15671daa0_0, v0x15671db50_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x15671da00_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x15671dc20_0, 0, 1;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x15671daa0_0, 0, 32;
    %delay 5000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x15671dc20_0, 0, 1;
    %delay 5000, 0;
    %pushi/vec4 5, 0, 32;
    %store/vec4 v0x15671daa0_0, 0, 32;
    %delay 5000, 0;
    %pushi/vec4 10, 0, 32;
    %store/vec4 v0x15671daa0_0, 0, 32;
    %delay 10000, 0;
    %pushi/vec4 20, 0, 32;
    %store/vec4 v0x15671daa0_0, 0, 32;
    %delay 10000, 0;
    %pushi/vec4 30, 0, 32;
    %store/vec4 v0x15671daa0_0, 0, 32;
    %vpi_call/w 3 34 "$finish" {0 0 0};
    %end;
    .thread T_2;
# The file index is used to find the file name in the following table.
:file_names 5;
    "N/A";
    "<interactive>";
    "-";
    "tb/pc_tb.sv";
    "rtl/core/pc.sv";
